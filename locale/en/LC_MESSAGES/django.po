msgstr "Knockout cannot be updated if there is no winner for the match."

#: enfrentamiento/views.py:740
msgid "El tercer set no puede terminar en empate."
msgstr "Third set cannot finish in draw."

#: enfrentamiento/views.py:742
msgid "Debe introducir el resultado del tercer set."
msgstr "You must introduce a result in third set."

#: enfrentamiento/views.py:744 enfrentamiento/views.py:748
msgid "En pádel no puede haber empates."
msgstr "In paddle, draws cannot happen."

#: enfrentamiento/views.py:746
msgid "Debe introducir el resultado del segundo set."
msgstr "You must introduce a result in second set."

#: enfrentamiento/views.py:750
msgid "Debe introducir el resultado del primer set."
msgstr "You must introduce a result in first set."

#: enfrentamiento/views.py:764
