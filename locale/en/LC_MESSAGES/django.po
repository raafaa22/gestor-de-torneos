#: enfrentamiento/forms.py:10
msgid "Estadística"
msgstr "Statistic"

#: enfrentamiento/forms.py:44
msgid "La cantidad debe ser al menos 1."
msgstr "The amount must be at least 1."

#: enfrentamiento/forms.py:68
msgid ""
"Ya existe una estadística de este tipo para el jugador en este "
"enfrentamiento."
msgstr ""
"There is already an existent statistic of this type for this player in this "
"match."

#: enfrentamiento/forms.py:77
msgid "No se pueden asignar asistencias si el equipo no ha anotado ningún gol."
msgstr "Assists cannot be added if there is no goal scored by the team."

#: enfrentamiento/forms.py:86
msgid ""
"El número total de asistencias no puede superar el número de goles anotados "
"por el equipo."
msgstr ""
"Total number of assists cannot be bigger than the number of scored goals by "
"the team."

#: enfrentamiento/forms.py:95
msgid ""
"No se pueden asignar asistencias si el equipo no ha anotado ningún tiro de "
"campo."
msgstr "Assists cannot be added if the team has not scored any field goal."

#: enfrentamiento/forms.py:104
msgid ""
"El número total de asistencias no puede superar el número de tiros de campo "
"anotados por el equipo."
msgstr ""
"Total number of assists cannot be bigger than the number of field goals scored by "
"the team."

