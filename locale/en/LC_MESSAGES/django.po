msgid "Número de equipos en descenso"
msgstr "Number of teams in relegation"

#: torneo/forms.py:62
msgid ""
"Debe especificar el número de equipos en play-offs si ha marcado que hay "
"play-offs."
msgstr "You must specify number of teams in play-offs if play-offs is marked."

#: torneo/forms.py:64
msgid ""
"El número de equipos en play-offs no puede ser mayor que el número máximo de "
"equipos del torneo."
msgstr ""
"Number of teams in play-offs cannot be bigger than the maximum of the "
"tournament."

#: torneo/forms.py:66
msgid ""
"El número de equipos en play-offs no puede ser mayor que 32 ya que como "
"máximo puede haber 5 rondas en una eliminatoria."
msgstr ""
"Number of teams in play-offs cannot be bigger than 32 due to the maximum number of rounds in a knockout: 5."

#: torneo/forms.py:68
msgid "El número de equipos en play-offs no puede ser menor que 2."
msgstr ""
"Number of temas in play-offs cannot be smaller than 2."

#: torneo/forms.py:76
msgid ""
"Debe especificar el número de equipos en descenso si ha marcado que hay "
"descenso."
msgstr ""
"You must specify number of teams in relegation if relegation is marked."

#: torneo/forms.py:78
msgid ""
"El número de equipos en descenso no puede ser mayor que el número máximo de "
"equipos del torneo."
msgstr ""
"Number of temas in relegation cannot be bigger than the maximum of the "
"tournament."

#: torneo/forms.py:86
msgid ""
"La suma de equipos en play-offs y en descenso no puede ser mayor que el "
"número máximo de equipos del torneo."
msgstr ""
"The sum of teams in play-offs and relegation cannot be bigger than the "
"maximum of the tournament."

